{
    "name": "crustum/essentia",
    "description": "Detect packages and approaches in use within a CakePHP project",
    "type": "cakephp-plugin",
    "license": "MIT",
    "keywords": [
        "cakephp",
        "roster",
        "packages",
        "scanner"
    ],
    "authors": [
        {
            "name": "Evgeny Tomenko",
            "homepage": "https://github.com/skie"
        }
    ],
    "require": {
        "php": ">=8.3",
        "cakephp/cakephp": "^5.0",
        "laravel/agent-detector": "^2.0.2"
    },
    "require-dev": {
        "brianium/paratest": "^7.20.0",
        "cakephp/cakephp-codesniffer": "^5.0",
        "pestphp/pest": "^4.7.2 || ^5.0.0",
        "pestphp/pest-plugin-type-coverage": "^4.0.4 || ^5.0.0",
        "phpstan/phpstan": "^2.2.2",
        "rector/rector": "^2.4.5",
        "symfony/process": "^7.4.8 || ^8.1.0",
        "symfony/var-dumper": "^7.4.8 || ^8.1.0"
    },
    "autoload": {
        "files": [
            "src/Autoload.php"
        ],
        "psr-4": {
            "Crustum\\Essentia\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "TestApp\\": "tests/TestApp/",
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "check": [
            "@cs-check",
            "@test",
            "@stan"
        ],
        "cs-check": "phpcs -p --standard=phpcs.xml src/",
        "cs-fix": "phpcbf --standard=phpcs.xml src/",
        "test": "pest",
        "test:unit": "pest --testsuite=Unit",
        "stan": "phpstan analyse src/",
        "stan-baseline": "phpstan analyse --generate-baseline"
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "extra": {
        "pest": {
            "plugins": [
                "Crustum\\Essentia\\Drivers\\Pest\\Plugin"
            ]
        }
    },
    "config": {
        "allow-plugins": {
            "dealerdirect/phpcodesniffer-composer-installer": true,
            "pestphp/pest-plugin": true
        },
        "platform-check": false
    }
}
